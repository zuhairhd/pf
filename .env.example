# AI Personal CFO / Financial Digital Twin SaaS Platform
# Environment Variable Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Application
APP_NAME=PF AI Personal Finance
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
# Format: postgresql://user:password@host:port/database
# Password with special chars must be URL-encoded (@ = %40)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# AI / OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_PREMIUM=gpt-4o
AI_MAX_REQUESTS_PER_DAY_FREE=5
AI_MAX_REQUESTS_PER_DAY_PREMIUM=50

# Email / Notifications
EMAIL_DEV_MODE=true
EMAIL_BACKEND=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=PF AI Personal Finance
NOTIFICATIONS_ENABLED=true
BILL_REMINDER_DAYS_DEFAULT=3
SUBSCRIPTION_REMINDER_DAYS_DEFAULT=7

# File Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
DOCUMENT_UPLOAD_DIR=uploads/documents
DOCUMENT_MAX_UPLOAD_MB=10
DOCUMENT_ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,webp,txt,csv
OCR_ENABLED=false
OCR_DEV_MODE=true
OCR_ENGINE=auto
OCR_MAX_TEXT_LENGTH=100000
OCR_TIMEOUT_SECONDS=30
OCR_ALLOW_IMAGE_OCR=false
OCR_ALLOW_PDF_TEXT_EXTRACTION=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
CURRENCY_DEFAULT=OMR
CURRENCY_DECIMALS=3
